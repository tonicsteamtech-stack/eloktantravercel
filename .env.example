# Runtime
NODE_ENV=development
HOST=0.0.0.0
LOG_LEVEL=debug
REQUEST_TIMEOUT_MS=10000
SHUTDOWN_TIMEOUT_MS=10000
CORS_ORIGINS=http://localhost:3000

# Security
JWT_SECRET=replace-with-at-least-32-char-secret
JWT_EXPIRES_IN=12h
ADMIN_API_KEY=replace-with-admin-api-key
SERVICE_AUTH_TOKEN=replace-with-shared-internal-token

# Database / Supabase
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/eloktantra
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
# Optional fallback if service role key is unavailable
SUPABASE_ANON_KEY=

# Service ports
AUTH_SERVICE_PORT=4001
CANDIDATE_SERVICE_PORT=4002
MANIFESTO_SERVICE_PORT=4003
ISSUE_SERVICE_PORT=4004
DEBATE_SERVICE_PORT=4005
PROMISE_SERVICE_PORT=4006
VOTING_SERVICE_PORT=4007
IDENTITY_SERVICE_PORT=4008
LEDGER_SERVICE_PORT=4009
AUDIT_SERVICE_PORT=4010
AI_SERVICE_PORT=4011



#


# Service URLs (optional; defaults to localhost:<PORT>)
AUTH_SERVICE_URL=http://localhost:4001
CANDIDATE_SERVICE_URL=http://localhost:4002
MANIFESTO_SERVICE_URL=http://localhost:4003
ISSUE_SERVICE_URL=http://localhost:4004
PROMISE_SERVICE_URL=http://localhost:4006
VOTING_SERVICE_URL=http://localhost:4007
IDENTITY_SERVICE_URL=http://localhost:4008
LEDGER_SERVICE_URL=http://localhost:4009
AUDIT_SERVICE_URL=http://localhost:4010

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_REQUEST_TIMEOUT_MS=10000
NEXT_PUBLIC_DEMO_VOTER_ID=db7a4175-91fb-40d2-97ab-afaa1febdcdc
NEXT_PUBLIC_DEMO_REPORTER_ID=db7a4175-91fb-40d2-97ab-afaa1febdcdc
