{
  "name": "eloktantra-monorepo",
  "version": "0.0.0",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*",
    "desktop-client"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --concurrency 20",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "next": "15.5.15",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "@types/react": "19.0.8",
    "@types/react-dom": "19.0.3",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "turbo": "^1.12.0",
    "typescript": "^5.0.0"
  }
}
